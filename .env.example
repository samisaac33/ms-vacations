# URL pública del sitio (enlaces, metadata, redirecciones de pago)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contacto visible en el sitio
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_WHATSAPP=593998297151

# PostgreSQL (requerido en producción para reservas, iCal y precios)
DATABASE_URL=postgresql://user:password@localhost:5432/ms_vacations

# Panel admin (/admin) — contraseña de acceso
ADMIN_SECRET=

# Cron Vercel: sincronización diaria de calendarios iCal
CRON_SECRET=

# Supabase Storage — comprobantes de transferencia bancaria
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Transferencia bancaria (datos mostrados al huésped)
BANK_ACCOUNT_HOLDER=
BANK_NAME=
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_TYPE=
BANK_ID_TYPE=
BANK_ID_NUMBER=
BANK_EMAIL=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPhone
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=
PAYPHONE_DEFAULT_PHONE=+593999999999
PAYPHONE_DEFAULT_DOCUMENT=9999999999

# Entorno
NODE_ENV=development
